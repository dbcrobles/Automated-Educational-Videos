# Secrets — NEVER commit
.env

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/

# Database (local state)
Backend/database/db.sqlite

# Generated media & pipeline intermediates
Backend/assets/*
!Backend/assets/music/
Backend/assets/music/**/*.mp3
Backend/assets/sfx/
!Backend/assets/intros/
Backend/assets/intros/**/*.mp4

# Remotion / Node
Backend/remotion/node_modules/
Backend/remotion/public/[0-9]*
Backend/remotion/public/music
Backend/remotion/public/sfx

# Reflex frontend build artifacts
Frontend/.web/
Frontend/reflex.lock/
Frontend/uploaded_files/
Frontend/assets/preview_*.mp4
# Stray/legacy local DBs
Backend/database/*.db

# Runtime heartbeat
Backend/orchestrator.heartbeat
Backend/orchestrator.lock
